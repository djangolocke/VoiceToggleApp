<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#1A1D27">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configure Toggle"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilToggleName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Toggle name (e.g. WiFi)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="#5B6EF5"
        app:hintTextColor="#8A8F9E"
        android:layout_marginBottom="14dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etToggleName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:inputType="text"
            android:maxLines="1"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ICON"
        android:textColor="#8A8F9E"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="10dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/llIconPicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilOnCommand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Voice ON keyword (e.g. turn on wifi)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="#4CAF50"
        app:hintTextColor="#8A8F9E"
        android:layout_marginBottom="14dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etOnCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:inputType="text"
            android:maxLines="1"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilOffCommand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Voice OFF keyword (e.g. turn off wifi)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="#F44336"
        app:hintTextColor="#8A8F9E"
        android:layout_marginBottom="8dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etOffCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:inputType="text"
            android:maxLines="1"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice commands match if your speech contains the keyword phrase."
        android:textColor="#5A5E70"
        android:textSize="11sp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelToggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:layout_marginEnd="8dp"
            app:backgroundTint="#2A2D3A"
            app:cornerRadius="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveToggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save Toggle"
            android:layout_marginStart="8dp"
            app:backgroundTint="#5B6EF5"
            app:cornerRadius="12dp"/>
    </LinearLayout>

</LinearLayout>
