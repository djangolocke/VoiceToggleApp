<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117">

    <!-- Header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Voice Toggle"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Control switches with your voice"
        android:textSize="14sp"
        android:textColor="#8A8F9E"
        android:paddingHorizontal="24dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Voice status banner -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardVoiceStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="#1A1D27"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ivVoiceIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_mic"
                android:background="@drawable/bg_mic_button"
                android:padding="8dp"
                android:contentDescription="Microphone"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvVoiceStatusLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice Recognition"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvVoiceStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap the mic to start"
                    android:textColor="#8A8F9E"
                    android:textSize="13sp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Listen"
                android:textSize="13sp"
                app:backgroundTint="#5B6EF5"
                app:cornerRadius="12dp"
                android:paddingHorizontal="16dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Last heard command -->
    <TextView
        android:id="@+id/tvLastCommand"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text='Say "turn on WiFi", "disable Bluetooth", etc.'
        android:textColor="#5B6EF5"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingVertical="10dp"
        android:background="#1A1D27"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardVoiceStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Toggles Label -->
    <TextView
        android:id="@+id/tvTogglesLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="YOUR TOGGLES"
        android:textColor="#8A8F9E"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvLastCommand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- RecyclerView for toggles -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerToggles"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvTogglesLabel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Add Toggle FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Toggle"
        android:textColor="#FFFFFF"
        app:icon="@drawable/ic_add"
        app:iconTint="#FFFFFF"
        app:backgroundTint="#5B6EF5"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
